# TaskManager API — Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to version control!

# Security (REQUIRED — change before production!)
SECRET_KEY=your-super-secret-jwt-key-change-this-immediately

# Database (for future PostgreSQL integration)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/taskmanager

# Application
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Optional — external services
# SLACK_WEBHOOK_URL=https://hooks.slack.com/...
# SENTRY_DSN=https://...@sentry.io/...
